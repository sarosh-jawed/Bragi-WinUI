<Window
    x:Class="Bragi.App.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

  <Grid
        x:Name="RootGrid"
        Loaded="RootGrid_OnLoaded"
        Background="{StaticResource ShellBackgroundBrush}">

    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <NavigationView
            x:Name="ShellNavigationView"
            Grid.Row="0"
            Background="{StaticResource SidebarBackgroundBrush}"
            RequestedTheme="Dark"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="240"
            CompactPaneLength="48"
            PaneDisplayMode="Left"
            SelectionChanged="ShellNavigationView_OnSelectionChanged">

      <NavigationView.PaneHeader>
        <StackPanel Margin="0,12,0,16" Spacing="4">
          <TextBlock
                        Text="Bragi"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource SidebarForegroundBrush}" />
          <TextBlock
                        Text="{x:Bind ViewModel.CurrentStepTitle, Mode=OneWay}"
                        FontSize="14"
                        Foreground="{StaticResource SidebarMutedForegroundBrush}" />
        </StackPanel>
      </NavigationView.PaneHeader>

      <NavigationView.MenuItems>
        <NavigationViewItem
                    x:Name="StartNavigationItem"
                    Content="Start"
                    Tag="Start">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE80F;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem
                    x:Name="LoadInputNavigationItem"
                    Content="Load Input"
                    Tag="LoadInput">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE8B5;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem
                    x:Name="ReviewSubjectsNavigationItem"
                    Content="Review Subjects"
                    Tag="ReviewSubjects">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE9D5;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem
                    x:Name="PreviewResultsNavigationItem"
                    Content="Preview Results"
                    Tag="PreviewResults">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE8A5;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem
                    x:Name="ExportFinishNavigationItem"
                    Content="Export &amp; Finish"
                    Tag="ExportFinish">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE898;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>

      <Grid
                RequestedTheme="Light"
                Background="{StaticResource ContentBackgroundBrush}"
                Padding="{StaticResource ShellPadding}"
                RowSpacing="16">

        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
                    Grid.Row="0"
                    Text="{x:Bind ViewModel.ShellTitle, Mode=OneWay}"
                    Style="{StaticResource PageTitleTextBlockStyle}" />

        <StackPanel Grid.Row="1" Spacing="4">
          <TextBlock
                        Text="{x:Bind ViewModel.CurrentStepTitle, Mode=OneWay}"
                        Style="{StaticResource PageSectionTitleTextBlockStyle}" />
          <TextBlock
                        Text="{x:Bind ViewModel.CurrentStepDescription, Mode=OneWay}"
                        Style="{StaticResource PageMutedTextBlockStyle}" />
        </StackPanel>

        <Border
                    Grid.Row="2"
                    RequestedTheme="Light"
                    Style="{StaticResource AppCardBorderStyle}">

          <Frame
                        x:Name="ContentFrame"
                        RequestedTheme="Light" />
        </Border>
      </Grid>
    </NavigationView>

    <Border
            Grid.Row="1"
            Padding="{StaticResource FooterPadding}"
            Background="{StaticResource FooterBackgroundBrush}"
            BorderBrush="{StaticResource FooterBorderBrush}"
            BorderThickness="0,1,0,0">

      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">

          <ProgressRing
                        Width="18"
                        Height="18"
                        IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />

          <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{StaticResource SidebarForegroundBrush}"
                        Text="{x:Bind ViewModel.BusyStatusText, Mode=OneWay}" />

          <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{StaticResource SidebarMutedForegroundBrush}"
                        Text="{x:Bind ViewModel.NavigationStatusText, Mode=OneWay}" />
        </StackPanel>

        <Button
                    Grid.Column="1"
                    MinWidth="96"
                    Content="Back"
                    Click="BackButton_OnClick"
                    IsEnabled="{x:Bind ViewModel.CanMovePrevious, Mode=OneWay}" />

        <Button
                    Grid.Column="2"
                    MinWidth="96"
                    Content="Next"
                    Click="NextButton_OnClick"
                    IsEnabled="{x:Bind ViewModel.CanMoveNext, Mode=OneWay}" />

        <Button
                    Grid.Column="3"
                    MinWidth="96"
                    Content="Cancel"
                    Click="CancelButton_OnClick"
                    IsEnabled="{x:Bind ViewModel.CanCancelBusyOperation, Mode=OneWay}" />
      </Grid>
    </Border>
  </Grid>
</Window>
