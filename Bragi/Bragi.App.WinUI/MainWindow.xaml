<Window
    x:Class="Bragi.App.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

  <Grid x:Name="RootGrid" Loaded="RootGrid_OnLoaded">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <NavigationView
            x:Name="ShellNavigationView"
            Grid.Row="0"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="240"
            CompactPaneLength="48"
            PaneDisplayMode="Left"
            SelectionChanged="ShellNavigationView_OnSelectionChanged">

      <NavigationView.MenuItems>
        <NavigationViewItem
                    x:Name="StartNavigationItem"
                    Tag="0"
                    Content="Start">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="Home" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem
                    x:Name="LoadInputNavigationItem"
                    Tag="1"
                    Content="Load Input">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="OpenFile" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem
                    x:Name="ReviewSubjectsNavigationItem"
                    Tag="2"
                    Content="Review Subjects">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="List" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem
                    x:Name="PreviewResultsNavigationItem"
                    Tag="3"
                    Content="Preview Results">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="Preview" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItem
                    x:Name="ExportFinishNavigationItem"
                    Tag="4"
                    Content="Export &amp; Finish">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="Save" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>

      <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
                    Grid.Row="0"
                    Text="{x:Bind ViewModel.ShellTitle, Mode=OneWay}"
                    Style="{StaticResource TitleLargeTextBlockStyle}" />

        <StackPanel Grid.Row="1" Spacing="4">
          <TextBlock
                        Text="{x:Bind ViewModel.CurrentStepTitle, Mode=OneWay}"
                        Style="{StaticResource TitleMediumTextBlockStyle}" />
          <TextBlock
                        Text="{x:Bind ViewModel.CurrentStepDescription, Mode=OneWay}"
                        TextWrapping="WrapWholeWords"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Border
                    Grid.Row="2"
                    Padding="0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
          <Frame x:Name="ContentFrame" />
        </Border>
      </Grid>
    </NavigationView>

    <Border
            Grid.Row="1"
            Padding="20,14"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
          <ProgressRing
                        Width="18"
                        Height="18"
                        IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
          <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.BusyStatusText, Mode=OneWay}" />
          <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.NavigationStatusText, Mode=OneWay}" />
        </StackPanel>

        <Button
                    Grid.Column="1"
                    MinWidth="96"
                    Content="Back"
                    Click="BackButton_OnClick"
                    IsEnabled="{x:Bind ViewModel.CanMovePrevious, Mode=OneWay}" />

        <Button
                    Grid.Column="2"
                    MinWidth="96"
                    Content="Next"
                    Click="NextButton_OnClick"
                    IsEnabled="{x:Bind ViewModel.CanMoveNext, Mode=OneWay}" />

        <Button
                    Grid.Column="3"
                    MinWidth="96"
                    Content="Cancel"
                    Click="CancelButton_OnClick"
                    IsEnabled="{x:Bind ViewModel.CanCancelBusyOperation, Mode=OneWay}" />
      </Grid>
    </Border>
  </Grid>
</Window>
