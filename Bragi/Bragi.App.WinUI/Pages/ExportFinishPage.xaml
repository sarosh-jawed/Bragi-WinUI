<Page
    x:Class="Bragi.App.WinUI.Pages.ExportFinishPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    Background="Transparent"
    Loaded="Page_OnLoaded"
    mc:Ignorable="d">

  <ScrollViewer>
    <StackPanel Padding="24" Spacing="16">

      <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Success"
                Title="Final export step"
                Message="Bragi keeps output filenames stable for downstream compatibility while generating a readable run summary and support-friendly file set." />

      <Border Style="{StaticResource AppCardBorderStyle}">
        <StackPanel Spacing="12">
          <TextBlock
                        Text="Export output"
                        Style="{StaticResource PageSectionTitleTextBlockStyle}" />

          <TextBox
                        IsReadOnly="True"
                        Text="{x:Bind ViewModel.SelectedOutputFolder, Mode=OneWay}" />

          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button
                            Content="Choose Output Folder"
                            Click="ChooseOutputFolderButton_OnClick"
                            MinWidth="170" />

            <Button
                            Content="Generate Output"
                            Click="GenerateOutputButton_OnClick"
                            MinWidth="150"
                            IsEnabled="{x:Bind ViewModel.CanGenerateOutput, Mode=OneWay}" />

            <Button
                            Content="Open Output Folder"
                            Click="OpenOutputFolderButton_OnClick"
                            MinWidth="160"
                            IsEnabled="{x:Bind ViewModel.CanOpenOutputFolder, Mode=OneWay}" />

            <Button
                            Content="Open Log Folder"
                            Click="OpenLogFolderButton_OnClick"
                            MinWidth="140"
                            IsEnabled="{x:Bind ViewModel.CanOpenLogFolder, Mode=OneWay}" />
          </StackPanel>

          <TextBlock
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        Style="{StaticResource PageMutedTextBlockStyle}" />
        </StackPanel>
      </Border>

      <StackPanel
                Spacing="16"
                Visibility="{x:Bind ViewModel.ExportResultsVisibility, Mode=OneWay}">

        <Border Style="{StaticResource AppCardBorderStyle}">
          <StackPanel Spacing="12">
            <TextBlock
                            Text="Generated files"
                            Style="{StaticResource PageSubsectionTitleTextBlockStyle}" />

            <ListView ItemsSource="{x:Bind ViewModel.GeneratedFiles, Mode=OneWay}" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource AppCardBorderStyle}">
          <StackPanel Spacing="12">
            <TextBlock
                            Text="Run summary"
                            Style="{StaticResource PageSubsectionTitleTextBlockStyle}" />

            <TextBox
                            Text="{x:Bind ViewModel.RunSummaryText, Mode=OneWay}"
                            Style="{StaticResource ReadOnlySummaryTextBoxStyle}" />
          </StackPanel>
        </Border>

      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Page>
