<Page
    x:Class="Bragi.App.WinUI.Pages.ExportFinishPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_OnLoaded">

  <ScrollViewer>
    <StackPanel Padding="24" Spacing="16">
      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <StackPanel Spacing="12">
          <TextBlock Text="Export output" Style="{StaticResource TitleMediumTextBlockStyle}" />

          <TextBox
                        IsReadOnly="True"
                        Text="{x:Bind ViewModel.SelectedOutputFolder, Mode=OneWay}" />

          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Choose Output Folder" Click="ChooseOutputFolderButton_OnClick" />
            <Button Content="Generate Output" Click="GenerateOutputButton_OnClick" />
            <Button Content="Open Output Folder" Click="OpenOutputFolderButton_OnClick" />
            <Button Content="Open Log Folder" Click="OpenLogFolderButton_OnClick" />
          </StackPanel>

          <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
        </StackPanel>
      </Border>

      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <StackPanel Spacing="12">
          <TextBlock Text="Generated files" Style="{StaticResource TitleSmallTextBlockStyle}" />
          <ListView ItemsSource="{x:Bind ViewModel.GeneratedFiles, Mode=OneWay}" />
        </StackPanel>
      </Border>

      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <StackPanel Spacing="12">
          <TextBlock Text="Run summary" Style="{StaticResource TitleSmallTextBlockStyle}" />
          <TextBox
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        MinHeight="180"
                        Text="{x:Bind ViewModel.RunSummaryText, Mode=OneWay}"
                        TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
