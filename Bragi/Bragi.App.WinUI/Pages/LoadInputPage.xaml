<Page
    x:Class="Bragi.App.WinUI.Pages.LoadInputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer>
    <StackPanel Padding="24" Spacing="16">
      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <StackPanel Spacing="12">
          <TextBlock Text="Choose input file" Style="{StaticResource TitleMediumTextBlockStyle}" />

          <TextBox
                        IsReadOnly="True"
                        Text="{x:Bind ViewModel.SelectedInputFilePath, Mode=OneWay}"
                        PlaceholderText="Choose a .txt or .csv file" />

          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Choose File" Click="ChooseFileButton_OnClick" />
            <Button Content="Reload Extraction" Click="ReloadButton_OnClick" />
          </StackPanel>

          <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
        </StackPanel>
      </Border>

      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <Grid ColumnSpacing="24" RowSpacing="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="File name" FontWeight="SemiBold" />
          <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.FileNameDisplay, Mode=OneWay}" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Detected kind" FontWeight="SemiBold" />
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.DetectedInputKind, Mode=OneWay}" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Total records read" FontWeight="SemiBold" />
          <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.TotalRecordsRead, Mode=OneWay}" />
        </Grid>
      </Border>

      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <Grid ColumnSpacing="24" RowSpacing="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Extracted subjects" FontWeight="SemiBold" />
          <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.ExtractedSubjectCount, Mode=OneWay}" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Ignored blanks" FontWeight="SemiBold" />
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.BlankOrIgnoredCount, Mode=OneWay}" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Duplicates" FontWeight="SemiBold" />
          <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.DuplicateCount, Mode=OneWay}" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Parse warnings" FontWeight="SemiBold" />
          <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.ParseWarningCount, Mode=OneWay}" />
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
