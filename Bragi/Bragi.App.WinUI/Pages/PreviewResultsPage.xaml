<Page
    x:Class="Bragi.App.WinUI.Pages.PreviewResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Bragi.App.WinUI.ViewModels"
    Loaded="Page_OnLoaded">

  <ScrollViewer>
    <StackPanel Padding="24" Spacing="16">
      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <StackPanel Spacing="12">
          <TextBlock Text="Preview categorized results" Style="{StaticResource TitleMediumTextBlockStyle}" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Generate Preview" Click="GeneratePreviewButton_OnClick" />
          </StackPanel>
          <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
        </StackPanel>
      </Border>

      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <Grid ColumnSpacing="24" RowSpacing="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Total category assignments" FontWeight="SemiBold" />
          <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.TotalAssignments, Mode=OneWay}" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Uncategorized subjects" FontWeight="SemiBold" />
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.UncategorizedCount, Mode=OneWay}" />
        </Grid>
      </Border>

      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <StackPanel Spacing="12">
          <TextBlock Text="Category counts" Style="{StaticResource TitleSmallTextBlockStyle}" />

          <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryCounts, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid ColumnSpacing="12" Margin="0,4,0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0" Text="{Binding DisplayName}" />
                  <TextBlock Grid.Column="1" Text="{Binding Count}" FontWeight="SemiBold" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <StackPanel Spacing="12">
          <TextBlock Text="Category preview" Style="{StaticResource TitleSmallTextBlockStyle}" />

          <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryGroups, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Expander Header="{Binding DisplayName}">
                  <StackPanel Spacing="10" Padding="8">
                    <TextBlock Text="{Binding Count}" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding Subjects}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Padding="8" Margin="0,0,0,8">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding SubjectText}" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding Reason}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                              <TextBlock Text="{Binding SourceMetadata}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Expander>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border
                Padding="20"
                CornerRadius="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
        <StackPanel Spacing="12">
          <TextBlock Text="Uncategorized preview" Style="{StaticResource TitleSmallTextBlockStyle}" />

          <ItemsControl ItemsSource="{x:Bind ViewModel.UncategorizedSubjects, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="8" Margin="0,0,0,8">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding SubjectText}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Reason}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{Binding SourceMetadata}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
