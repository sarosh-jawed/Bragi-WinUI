<Page
    x:Class="Bragi.App.WinUI.Pages.PreviewResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    Background="Transparent"
    Loaded="Page_OnLoaded"
    mc:Ignorable="d">

  <ScrollViewer>
    <StackPanel Padding="24" Spacing="16">

      <Border
                Background="{StaticResource WarningBannerBackgroundBrush}"
                BorderBrush="{StaticResource WarningBannerBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,16">

        <StackPanel Orientation="Horizontal" Spacing="10">
          <FontIcon
                        Glyph="&#xE7BA;"
                        Foreground="{StaticResource WarningBannerForegroundBrush}" />
          <StackPanel Spacing="2">
            <TextBlock
                            Text="Preview guidance"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WarningBannerForegroundBrush}" />
            <TextBlock
                            Text="High uncategorized counts usually indicate rule coverage gaps or expected legacy-compatible exclusions."
                            TextWrapping="Wrap"
                            Foreground="{StaticResource WarningBannerForegroundBrush}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource AppCardBorderStyle}">
        <StackPanel Spacing="12">
          <TextBlock
                        Text="Preview categorized results"
                        Style="{StaticResource PageSectionTitleTextBlockStyle}" />

          <Button
                        Content="Generate Preview"
                        Click="GeneratePreviewButton_OnClick"
                        MinWidth="160"
                        Margin="0,0,0,12"
                        IsEnabled="{x:Bind ViewModel.CanGeneratePreview, Mode=OneWay}" />

          <TextBlock
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        Style="{StaticResource PageMutedTextBlockStyle}" />
        </StackPanel>
      </Border>

      <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource AppCardBorderStyle}">
          <Grid ColumnSpacing="24" RowSpacing="10">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Total category assignments" Style="{StaticResource MetricLabelTextBlockStyle}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.TotalAssignments, Mode=OneWay}" Style="{StaticResource MetricAccentValueTextBlockStyle}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Uncategorized subjects" Style="{StaticResource MetricLabelTextBlockStyle}" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.UncategorizedCount, Mode=OneWay}" Style="{StaticResource MetricAccentValueTextBlockStyle}" />
          </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource AppCardBorderStyle}">
          <StackPanel Spacing="12">
            <TextBlock
                            Text="Category counts"
                            Style="{StaticResource PageSubsectionTitleTextBlockStyle}" />

            <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryCounts, Mode=OneWay}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnSpacing="12" Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" />
                    <TextBlock Grid.Column="1" Text="{Binding Count}" Style="{StaticResource MetricAccentValueTextBlockStyle}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>

      <Border Style="{StaticResource AppCardBorderStyle}">
        <StackPanel Spacing="12">
          <TextBlock
                        Text="Category preview"
                        Style="{StaticResource PageSubsectionTitleTextBlockStyle}" />

          <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryGroups, Mode=OneWay}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Expander Header="{Binding DisplayName}" Margin="0,0,0,10">
                    <StackPanel Spacing="10" Padding="8">
                      <TextBlock Text="{Binding Count}" Style="{StaticResource MetricAccentValueTextBlockStyle}" />
                      <ItemsControl ItemsSource="{Binding Subjects}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Style="{StaticResource AppSubtleCardBorderStyle}" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <TextBlock Text="{Binding SubjectText}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Reason}" Style="{StaticResource PageMutedTextBlockStyle}" />
                                <TextBlock Text="{Binding SourceMetadata}" Style="{StaticResource PageMutedTextBlockStyle}" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Expander>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource AppCardBorderStyle}">
        <StackPanel Spacing="12">
          <TextBlock
                        Text="Uncategorized preview"
                        Style="{StaticResource PageSubsectionTitleTextBlockStyle}" />

          <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{x:Bind ViewModel.UncategorizedSubjects, Mode=OneWay}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource AppSubtleCardBorderStyle}" Margin="0,0,0,8">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding SubjectText}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Reason}" Style="{StaticResource PageMutedTextBlockStyle}" />
                      <TextBlock Text="{Binding SourceMetadata}" Style="{StaticResource PageMutedTextBlockStyle}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
