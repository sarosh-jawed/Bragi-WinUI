<Page
    x:Class="Bragi.App.WinUI.Pages.ReviewSubjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    Background="Transparent"
    mc:Ignorable="d">

  <ScrollViewer>
    <StackPanel Padding="24" Spacing="16">

      <Border Style="{StaticResource AppCardBorderStyle}">
        <StackPanel Spacing="12">
          <TextBlock
                        Text="Review extracted subjects"
                        Style="{StaticResource PageSectionTitleTextBlockStyle}" />

          <TextBlock
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        Style="{StaticResource PageMutedTextBlockStyle}" />

          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button
                            Content="{x:Bind ViewModel.ReviewCompletionButtonText, Mode=OneWay}"
                            IsEnabled="{x:Bind ViewModel.CanMarkReviewComplete, Mode=OneWay}"
                            Click="MarkReviewCompleteButton_OnClick"
                            MinWidth="180" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource AppCardBorderStyle}">
        <Grid ColumnSpacing="24" RowSpacing="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Extracted subjects" Style="{StaticResource MetricLabelTextBlockStyle}" />
          <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.ExtractedSubjectCount, Mode=OneWay}" Style="{StaticResource MetricAccentValueTextBlockStyle}" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Duplicates" Style="{StaticResource MetricLabelTextBlockStyle}" />
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.DuplicateCount, Mode=OneWay}" Style="{StaticResource MetricValueTextBlockStyle}" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Ignored blanks" Style="{StaticResource MetricLabelTextBlockStyle}" />
          <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.BlankOrIgnoredCount, Mode=OneWay}" Style="{StaticResource MetricValueTextBlockStyle}" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Parse warnings" Style="{StaticResource MetricLabelTextBlockStyle}" />
          <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.ParseWarningCount, Mode=OneWay}" Style="{StaticResource MetricValueTextBlockStyle}" />
        </Grid>
      </Border>

      <Border Style="{StaticResource AppCardBorderStyle}">
        <StackPanel Spacing="12">
          <TextBlock
                        Text="Preview list"
                        Style="{StaticResource PageSubsectionTitleTextBlockStyle}" />
          <TextBlock
                        Text="{x:Bind ViewModel.PreviewWindowText, Mode=OneWay}"
                        Style="{StaticResource PageMutedTextBlockStyle}" />

          <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
            <ListView ItemsSource="{x:Bind ViewModel.Subjects, Mode=OneWay}">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource AppSubtleCardBorderStyle}" Margin="0,0,0,10">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Subject}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding SourceMetadata}" Style="{StaticResource PageMutedTextBlockStyle}" />
                      <TextBlock Text="{Binding OptionalMetadata}" Style="{StaticResource PageMutedTextBlockStyle}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </ScrollViewer>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
