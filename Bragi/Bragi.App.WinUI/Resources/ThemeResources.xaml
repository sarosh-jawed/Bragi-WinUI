<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Core palette -->
  <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#F3F4F6" />
  <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#F3F4F6" />
  <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#111827" />
  <SolidColorBrush x:Key="SidebarBorderBrush" Color="#1F2937" />
  <SolidColorBrush x:Key="SidebarForegroundBrush" Color="#F9FAFB" />
  <SolidColorBrush x:Key="SidebarMutedForegroundBrush" Color="#CBD5E1" />
  <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#0B1220" />
  <SolidColorBrush x:Key="FooterBorderBrush" Color="#1F2937" />

  <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
  <SolidColorBrush x:Key="CardSubtleBackgroundBrush" Color="#F9FAFB" />
  <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E7EB" />

  <SolidColorBrush x:Key="PageTitleBrush" Color="#111827" />
  <SolidColorBrush x:Key="PageSubtitleBrush" Color="#4B5563" />

  <!-- Updated Content Brushes -->
  <SolidColorBrush x:Key="ContentForegroundBrush" Color="#FF1F2937" />
  <SolidColorBrush x:Key="ContentMutedForegroundBrush" Color="#FF6B7280" />

  <!-- Info Banner Brushes -->
  <SolidColorBrush x:Key="InfoBannerBackgroundBrush" Color="#FFE8F4FD" />
  <SolidColorBrush x:Key="InfoBannerBorderBrush" Color="#FFB9DDF5" />
  <SolidColorBrush x:Key="InfoBannerForegroundBrush" Color="#FF12344D" />

  <!-- Warning Banner Brushes -->
  <SolidColorBrush x:Key="WarningBannerBackgroundBrush" Color="#FFF8E7C2" />
  <SolidColorBrush x:Key="WarningBannerBorderBrush" Color="#FFE0B84E" />
  <SolidColorBrush x:Key="WarningBannerForegroundBrush" Color="#FF6F4E00" />

  <!-- Success Banner Brushes -->
  <SolidColorBrush x:Key="SuccessBannerBackgroundBrush" Color="#FFE7F6EA" />
  <SolidColorBrush x:Key="SuccessBannerBorderBrush" Color="#FF97D7A6" />
  <SolidColorBrush x:Key="SuccessBannerForegroundBrush" Color="#FF124B22" />

  <SolidColorBrush x:Key="AccentGoldBrush" Color="#D4A017" />
  <SolidColorBrush x:Key="AccentGoldForegroundBrush" Color="#1F2937" />

  <SolidColorBrush x:Key="SuccessBrush" Color="#166534" />
  <SolidColorBrush x:Key="WarningBrush" Color="#B45309" />
  <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />

  <!-- Spacing / shape -->
  <CornerRadius x:Key="CardCornerRadius">16</CornerRadius>
  <CornerRadius x:Key="SmallCornerRadius">12</CornerRadius>

  <Thickness x:Key="ShellPadding">24</Thickness>
  <Thickness x:Key="CardPadding">20</Thickness>
  <Thickness x:Key="CardInnerPadding">14</Thickness>
  <Thickness x:Key="FooterPadding">20,14</Thickness>

  <!-- Typography -->
  <Style x:Key="PageTitleTextBlockStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource PageTitleBrush}" />
  </Style>

  <Style x:Key="PageSectionTitleTextBlockStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource ContentForegroundBrush}" />
  </Style>

  <Style x:Key="PageSubsectionTitleTextBlockStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource ContentForegroundBrush}" />
  </Style>

  <Style x:Key="PageBodyTextBlockStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource ContentForegroundBrush}" />
    <Setter Property="TextWrapping" Value="WrapWholeWords" />
  </Style>

  <Style x:Key="PageMutedTextBlockStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource ContentMutedForegroundBrush}" />
    <Setter Property="TextWrapping" Value="WrapWholeWords" />
  </Style>

  <Style x:Key="MetricLabelTextBlockStyle" TargetType="TextBlock">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource ContentForegroundBrush}" />
  </Style>

  <Style x:Key="MetricValueTextBlockStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource ContentForegroundBrush}" />
  </Style>

  <Style x:Key="MetricAccentValueTextBlockStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource AccentGoldBrush}" />
  </Style>

  <!-- Shared cards -->
  <Style x:Key="AppCardBorderStyle" TargetType="Border">
    <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
  </Style>

  <Style x:Key="AppSubtleCardBorderStyle" TargetType="Border">
    <Setter Property="Padding" Value="{StaticResource CardInnerPadding}" />
    <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{StaticResource CardSubtleBackgroundBrush}" />
  </Style>

  <!-- Read-only summary area -->
  <Style x:Key="ReadOnlySummaryTextBoxStyle" TargetType="TextBox">
    <Setter Property="IsReadOnly" Value="True" />
    <Setter Property="AcceptsReturn" Value="True" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="MinHeight" Value="220" />
    <Setter Property="FontFamily" Value="Consolas" />
  </Style>
</ResourceDictionary>
